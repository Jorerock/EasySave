<Window x:Class="EasySave.WPF.Views.AppSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:domain="clr-namespace:EasySave.Core.Domain;assembly=EasySave.Core"
        Title="{DynamicResource Settings_Title}"
        MinHeight="600" MinWidth="500" Width="600" Height="750"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- OK : dictionnaire thème -->
                <ResourceDictionary Source="/EasySaveWPF;component/Theme/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <ObjectDataProvider x:Key="LanguageEnumValues"
                                MethodName="GetValues"
                                ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="domain:AppLanguage"/>
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>

            <!-- Style Checkbox Moderne -->
            <Style x:Key="ModernCheckBox" TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="Margin" Value="0,4,16,4"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <!-- ✅ NOUVEAU : Style ComboBox Moderne (évite le crash) -->
            <Style x:Key="ModernComboBox" TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="MinHeight" Value="34"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>

            <Style x:Key="FieldHint" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SurfaceBrush}"
                Padding="24,16"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="{StaticResource IconFont}"
                           Text="&#xE713;"
                           FontSize="20"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Settings_Title}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>
            </StackPanel>
        </Border>

        <!-- Boutons Actions -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SurfaceBrush}"
                Padding="24,16"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource Common_Cancel}"
                        Width="100"
                        Click="Cancel_Click"
                        Style="{StaticResource ModernButton}"
                        Margin="0,0,12,0"/>
                <Button Content="{DynamicResource Common_Save}"
                        Width="120"
                        Click="Save_Click"
                        Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel>

                <!-- Section Application -->
                <TextBlock Text="{DynamicResource Settings_Section_App}"
                           Style="{StaticResource CardTitle}"
                           Margin="4,0,0,8"/>
                <Border Style="{StaticResource ModernCard}">
                    <StackPanel>
                        <!-- Langue -->
                        <TextBlock Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource Settings_Language}"/>
                        <!-- ✅ FIX : ComboBox = ModernComboBox -->
                        <ComboBox x:Name="LanguageComboBox"
                                  Style="{StaticResource ModernComboBox}"
                                  Margin="0,0,0,16"
                                  ItemsSource="{Binding Source={StaticResource LanguageEnumValues}}"/>

                        <!-- Logiciel métier -->
                        <TextBlock Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource Settings_BusinessSoftwarePath}"/>
                        <TextBlock Style="{StaticResource FieldHint}"
                                   Text="{DynamicResource Settings_BusinessSoftwareHint}"/>
                        <TextBox x:Name="SourceTextBox"
                                 Style="{StaticResource ModernTextBox}"
                                 ToolTip="{DynamicResource Settings_BusinessSoftwareTooltip}"/>
                        <!-- ✨ CryptoSoft Path -->
                        <TextBlock Style="{StaticResource FieldLabel}"
           Text="CryptoSoft.exe Path"/>
                        <TextBlock Style="{StaticResource FieldHint}"
           Text="Path to the encryption executable (CryptoSoft.exe)"/>
                        <TextBox x:Name="CryptoSoftPathTextBox"
         Style="{StaticResource ModernTextBox}"
         Margin="0,0,0,16"
         ToolTip="Example: C:\Tools\CryptoSoft\CryptoSoft.exe"/>
                    </StackPanel>
                    
                    
                </Border>

                <!-- Section Extensions -->
                <TextBlock Text="{DynamicResource Settings_Section_Extensions}"
                           Style="{StaticResource CardTitle}"
                           Margin="4,0,0,8"/>
                <Border Style="{StaticResource ModernCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource Settings_ExtensionsToEncrypt}"/>
                        <WrapPanel Margin="0,0,0,16">
                            <CheckBox x:Name="TxtCheckBox" Content=".txt" Style="{StaticResource ModernCheckBox}"/>
                            <CheckBox x:Name="CsvCheckBox" Content=".csv" Style="{StaticResource ModernCheckBox}"/>
                            <CheckBox x:Name="PngCheckBox" Content=".png" Style="{StaticResource ModernCheckBox}"/>
                            <CheckBox x:Name="JpgCheckBox" Content=".jpg" Style="{StaticResource ModernCheckBox}"/>
                            <CheckBox x:Name="DocxCheckBox" Content=".docx" Style="{StaticResource ModernCheckBox}"/>
                            <CheckBox x:Name="PdfCheckBox" Content=".pdf" Style="{StaticResource ModernCheckBox}"/>
                        </WrapPanel>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>

                        <TextBlock Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource Settings_PriorityExtensions}"/>
                        <TextBlock Style="{StaticResource FieldHint}"
                                   Text="{DynamicResource Settings_PriorityExtensionsHint}"/>
                        <WrapPanel>
                            <CheckBox x:Name="PriorityPdfCheckBox" Content=".pdf" Style="{StaticResource ModernCheckBox}"/>
                            <CheckBox x:Name="PriorityDocxCheckBox" Content=".docx" Style="{StaticResource ModernCheckBox}"/>
                            <CheckBox x:Name="PriorityTxtCheckBox" Content=".txt" Style="{StaticResource ModernCheckBox}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Section Logs -->
                <TextBlock Text="{DynamicResource Settings_Section_Logs}"
                           Style="{StaticResource CardTitle}"
                           Margin="4,0,0,8"/>
                <Border Style="{StaticResource ModernCard}">
                    <StackPanel>
                        <!-- Format -->
                        <TextBlock Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource Settings_LogFormat}"/>
                        <!-- ✅ FIX : ComboBox = ModernComboBox -->
                        <ComboBox x:Name="LogFormatComboBox"
                                  Style="{StaticResource ModernComboBox}"
                                  Margin="0,0,0,16">
                            <ComboBoxItem Content="JSON" IsSelected="True"/>
                            <ComboBoxItem Content="XML"/>
                        </ComboBox>

                        <!-- Mode -->
                        <TextBlock Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource Settings_LogMode}"/>
                        <!-- ✅ FIX : ComboBox = ModernComboBox -->
                        <ComboBox x:Name="LogModeComboBox"
                                  Style="{StaticResource ModernComboBox}"
                                  Margin="0,0,0,16">
                            <ComboBoxItem Content="{DynamicResource Settings_LogMode_Local}" Tag="local" IsSelected="True"/>
                            <ComboBoxItem Content="{DynamicResource Settings_LogMode_Central}" Tag="central"/>
                            <ComboBoxItem Content="{DynamicResource Settings_LogMode_Both}" Tag="both"/>
                        </ComboBox>

                        <!-- Central URL -->
                        <TextBlock Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource Settings_CentralLogUrl}"/>
                        <TextBlock Style="{StaticResource FieldHint}"
                                   Text="{DynamicResource Settings_CentralLogUrlHint}"/>
                        <TextBox x:Name="CentralUrlTextBox"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>